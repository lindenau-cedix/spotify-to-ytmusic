# Copy to .env and fill in real values.
# This file MUST stay out of version control.

# Spotify Web App credentials: https://developer.spotify.com/dashboard
# Create an app, set Redirect URI to: http://localhost:8000/callback/spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/callback/spotify

# Where to put generated files. All paths are relative to the project root.
MIGRATOR_DATA_DIR=.migrator
MIGRATOR_DB_PATH=.migrator/migrator.db

# Local web server
MIGRATOR_HOST=127.0.0.1
MIGRATOR_PORT=8000

# Matching / concurrency
MIGRATOR_MATCH_CONCURRENCY=4
MIGRATOR_MATCH_THRESHOLD_ACCEPT=0.7
MIGRATOR_MATCH_THRESHOLD_REVIEW=0.4

# Logging
MIGRATOR_LOG_LEVEL=INFO